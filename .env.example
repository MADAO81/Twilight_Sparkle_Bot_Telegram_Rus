# ============================================
# 🦄 TWILIGHT SPARKLE BOT — НАСТРОЙКИ
# ============================================

# ========== TELEGRAM ==========
# Токен бота, получить у @BotFather
TELEGRAM_TOKEN=ваш_токен_бота

# ========== OPENAI ==========
# API ключ OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=ваш_ключ
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.85

# ========== КООРДИНАТЫ ПО УМОЛЧАНИЮ (Ворсино) ==========
DEFAULT_LAT=55.0965
DEFAULT_LON=36.6355

# ========== РАБОЧЕЕ ВРЕМЯ ==========
WORK_START_HOUR=9
WORK_END_HOUR=20

# ========== КОНТЕКСТ ==========
# Сколько дней хранить историю диалога
CONTEXT_EXPIRE_DAYS=30

# ========== АДМИНИСТРАТОР ==========
# Твой Telegram ID (для админ-команд)
ADMIN_ID=ваш_telegram_id

# ========== РЕЖИМ ОТЛАДКИ ==========
# true — включён, false — выключен
DEBUG_MODE=false

# ========== ПОДПИСКИ ==========
# ID чатов для автоматической подписки (через запятую, без пробелов)
DEFAULT_CHATS=
